// Prowider Mini Lead Distribution System — Database Schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Service {
  id               Int               @id @default(autoincrement())
  name             String
  leads            Lead[]
  allocationStates AllocationState[]
}

model Provider {
  id                 Int              @id @default(autoincrement())
  name               String
  monthlyQuota       Int              @default(10)
  leadsReceivedCount Int              @default(0)
  assignments        LeadAssignment[]
  allocationStates   AllocationState[]
}

model Lead {
  id          Int              @id @default(autoincrement())
  name        String
  phone       String
  city        String
  description String
  serviceId   Int
  service     Service          @relation(fields: [serviceId], references: [id])
  createdAt   DateTime         @default(now())
  assignments LeadAssignment[]

  @@unique([phone, serviceId])
}

model LeadAssignment {
  id         Int      @id @default(autoincrement())
  leadId     Int
  providerId Int
  assignedAt DateTime @default(now())
  lead       Lead     @relation(fields: [leadId], references: [id])
  provider   Provider @relation(fields: [providerId], references: [id])

  @@unique([leadId, providerId])
}

model AllocationState {
  id          Int      @id @default(autoincrement())
  serviceId   Int
  providerId  Int
  turnCounter Int      @default(0)
  service     Service  @relation(fields: [serviceId], references: [id])
  provider    Provider @relation(fields: [providerId], references: [id])

  @@unique([serviceId, providerId])
}

model WebhookIdempotencyKey {
  id             Int      @id @default(autoincrement())
  idempotencyKey String   @unique
  processedAt    DateTime @default(now())
}
